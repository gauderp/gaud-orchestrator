# Gaud Orchestrator — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# === Required ===

# GitHub Personal Access Token (fine-grained recommended)
# Create at: https://github.com/settings/tokens?type=beta
# Permissions needed: repo (full), read:org
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# === LLM Providers (configure at least one) ===

# Anthropic (Claude API) — for claude-api provider
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, etc.)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# === Git Identity (for commits and PRs) ===
GIT_AUTHOR_NAME=Gaud Orchestrator
GIT_AUTHOR_EMAIL=orchestrator@gaud.dev

# === Optional ===

# Server
# PORT=3001
# LOG_LEVEL=info

# Slack integration
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
