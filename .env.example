# Gaud Orchestrator — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# === API Provider Keys ===
# Configure these here OR via the Provider Config page in the UI.
# UI config is stored in SQLite and takes precedence.

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, o3-mini, etc.)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# === Server Config ===
# PORT=3001
# LOG_LEVEL=info
# DATABASE_PATH=data/orchestrator.db
# AGENTS_DIR=agents
# ATTACHMENTS_DIR=data/attachments
